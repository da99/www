#!/usr/bin/env bash

THIS_DIR="$(dirname "$0")/.."
#
# Color_Off='\e[0m'
# Bold="$(tput bold)"
# Reset='\e[0m'
# BRed='\e[1;31m'
# Red='\e[0;31m'
# Green='\e[0;32m'
# BGreen='\e[1;32m'
# Orange='\e[0;33m'
# BOrange='\e[1;33m'

case "$*" in
  --help|help|-h)
  cmd="$(basename "$0")"
  echo "$cmd setup bucket"
  echo "     Create the sqlite database to remember uploaded/pruned public files."
  echo "$cmd update file manifest"
  echo "     Updates the \"public_files\" Array in settings.json"
  echo "$cmd upload to bucket"
  echo "$cmd prune files"
  echo "$cmd build mjs"
  echo "$cmd serve"
  echo "$cmd list old|new files"
  ;;

  "upload to bucket"|"setup bucket")
    bun run "$THIS_DIR"/src/Public_File.mts "$@"
  ;;

  "update file manifest")
    "$THIS_DIR"/src/Bucket.rb "$@"
  ;;

  "set src to "*)
    "$THIS_DIR"/src/PublicFile.rb "$@"
    ;;

  'build mjs')
    case "$PWD/" in
      */build/*) : ;;
      *)
        echo "!!! Not in a build directory: $PWD" >&2
        exit 1
        ;;
    esac
    # "$THIS_DIR"/src/PublicFile.rb build mjs
    set -x
    index_mts=$( find public/section -maxdepth 2 -mindepth 2 -type f -iname '*.mts' -and -not -iname '*.html.mts')
    # index_mts=$( echo public/section/**/*.html.mts )
    bun build \
      --target browser \
      --outdir "$PWD"/public/section \
      --splitting \
      --chunk-naming "[dir]/[name].mjs" \
      --entry-naming "[dir]/[name].mjs" \
      $index_mts
    rm $index_mts
  ;;

  'list new files'|'list old files')
    bun run "$THIS_DIR"/src/Public_File.mts "$@"
  ;;

  'public_file '*)
    shift
    bun run "$THIS_DIR"/src/Public_File.mts "$@"
  ;;

  'prune files')
    bun run "$THIS_DIR"/src/Public_File.mts "$@"
  ;;

  *)
    echo "!!! Unknown command: $*" >&2
    exit 1
  ;;
esac

